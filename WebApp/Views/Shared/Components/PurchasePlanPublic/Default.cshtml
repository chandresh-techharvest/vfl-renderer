    </div>
</div>


<!--End::row-1 -->
<!--purchase plan -->
<!-- Start::row-1 -->
<div class="row" id="selected-plan-view" style="display:none;">
    <div class="col-xl-12">
        <div class="card custom-card">
            <div class="card-body">
                <ul class="nav nav-tabs tab-style-1 d-sm-flex d-block" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" data-bs-target="#4gplans" href="#4gplans">4G Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" data-bs-target="#5gplans" href="#5gplans">5G Plans</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane active" id="4gplans" role="tabpanel">
                        <div class="row">
                            <div class="col-xl-12">
                                <div class="card custom-card bg-light">
                                    <div class="card-body">
                                        <form class="row row-cols-lg-auto g-3 align-items-center">
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Plan Type</label>
                                                    <select class="form-select" id="planTypeFilter">

                                                        <option value="">All Categories</option>

                                                        @if (Model?.PlanTypes != null)
                                                        {
                                                            foreach (var type in Model.PlanTypes)
                                                            {
                                                                <option value="@type.Identifier">
                                                                    @type.Name
                                                                </option>
                                                            }
                                                        }

                                                    </select>

                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Payment Type</label>
                                                    <select class="form-select" id="paymentTypeFilter">

                                                        <option value="">All Categories</option>

                                                        @if (Model?.PaymentMethods != null && Model.PaymentMethods.Any())
                                                        {
                                                            foreach (var method in Model.PaymentMethods)
                                                            {
                                                                <option value="@method.Identifier">
                                                                    @method.Name
                                                                </option>
                                                            }
                                                        }

                                                    </select>

                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Sort By</label>
                                                    <select class="form-select" id="sortFilter">
                                                        <option value="price_asc">Price: Low to High</option>
                                                        <option value="price_desc">Price: High to Low</option>
                                                        <option value="data_asc">Data: Low to High</option>
                                                        <option value="data_desc">Data: High to Low</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap justify-content-start gap-3 py-2">
                            <div class="row g-3 plan-selector" id="plansContainer">



                               



                            </div>
                        </div>



                        <!-- Pagination -->
                        <nav aria-label="Page navigation" class=" pagination-style-3 mt-3">
                            <ul class="pagination mb-0 flex-wrap" id="pagination4g"></ul>
                        </nav>
                    </div>

                    <div class="tab-pane" id="5gplans" role="tabpanel">
                        <div class="row">
                            <div class="col-xl-12">
                                <div class="card custom-card bg-light">
                                    <div class="card-body">
                                        <form class="row row-cols-lg-auto g-3 align-items-center">
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Plan Type</label>
                                                    <select class="form-select" id="planTypeFilter5g">
                                                        <option value="">All Categories</option>

                                                        @if (Model?.PlanTypes != null)
                                                        {
                                                            foreach (var type in Model.PlanTypes)
                                                            {
                                                                <option value="@type.Identifier">
                                                                    @type.Name
                                                                </option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Payment Type</label>
                                                    <select class="form-select" id="paymentTypeFilter5g">
                                                        <option selected value="">All Categories</option>
                                                        @if (Model?.PaymentMethods != null && Model.PaymentMethods.Any())
                                                        {
                                                            foreach (var method in Model.PaymentMethods)
                                                            {
                                                                <option value="@method.Identifier">
                                                                    @method.Name
                                                                </option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Sort By</label>
                                                    <select class="form-select" id="sortFilter5g">
                                                        <option selected>Price: Low to High</option>
                                                        <option value="1">Price: High to Low</option>
                                                        <option value="2">Data: Low to High</option>
                                                        <option value="3">Data: High to Low</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap justify-content-start gap-3 py-2">
                            <div class="row g-3 plan-selector" id="plansContainer5g">

                                

                            </div>
                        </div>

                        <!-- Pagination -->
                        <nav aria-label="Page navigation" class=" pagination-style-3 mt-3">
                            <ul class="pagination mb-0 flex-wrap" id="pagination5g"></ul>
                        </nav>
                    </div>


                </div>
                <div class="row">
                    <div class="col-md-12 mt-3">
                        <div class="d-flex justify-content-between">
                            <a href="purchaseplan" class="btn btn-primary" style="width: 100px;">Previous</a>
                            <a href="OTP-option2.html" class="btn btn-primary" style="width: 100px;" data-bs-toggle="modal" data-bs-target="#ModalConfirmation-purchaseplan">Continue</a>
                        </div>
                    </div>

                    <!-- confirmation modal -->
                    <div class="modal fade" id="ModalConfirmation-purchaseplan" tabindex="-1"
                         aria-labelledby="exampleModalScrollable2" data-bs-keyboard="false"
                         aria-hidden="true">
                        <!-- Scrollable modal -->
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">
                                        Confirmation
                                    </h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                                            aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Dear <span id="confirmUser"></span>,</p>
                                    <p>You are about to Purchase the following plan:</p>

                                    <ul class="list-unstyled mb-3">
                                        <li><strong>Plan Name:</strong> <span id="confirmPlan"></span></li>
                                        <li><strong>Price:</strong> <span id="confirmPrice"></span></li>
                                        <li><strong>Data:</strong> [data]</li>
                                        <li><strong>Voice Minutes:</strong> [voice_minutes]</li>
                                        <li><strong>SMS:</strong> [sms]</li>
                                        <li><strong>Mobile Number:</strong> <span id="confirmNumber"></span></li>
                                    </ul>

                                    <p>Do you wish to continue with the subscription?</p>
                                </div>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="button"
                                            class="btn btn-primary"
                                            id="confirmCheckoutBtn">
                                        Confirm
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- OTP Option -->
                    <div class="modal fade" id="exampleModalScrollable2" tabindex="-1" aria-labelledby="exampleModalScrollable2" data-bs-keyboard="false" aria-hidden="true">

                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">Select OTP Verification Method</h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <form>
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <div class="form-check form-check-md">
                                                <input class="form-check-input" type="radio" name="Radio" id="Radio-md" style="border: 1px solid rgb(117, 117, 117);">
                                                <label class="form-check-label" for="Radio-md"> Receive OTP via your mobile number</label>
                                            </div>
                                            <div class="form-check form-check-md">
                                                <input class="form-check-input" type="radio" name="Radio" id="Radio-md" style="border: 1px solid rgb(117, 117, 117);" ">
                                                <label class="form-check-label" for="Radio-md"> Receive OTP via your email address</label>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                            data-bs-dismiss="modal">
                                        Close
                                    </button>
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#otpmodal">verify</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- OTP -->
                    <div class="modal fade" id="otpmodal" tabindex="-1" aria-labelledby="otpmodal" data-bs-keyboard="false" aria-hidden="true">
                        <!-- Scrollable modal -->
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">OTP Verification</h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="mb-4">Please enter the 4 digit code sent to ********25</p>
                                    <form>
                                        <div class="mb-3">
                                            <input type="number" class="form-control" id="device-name">
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-primary">Resend</button>
                                    <a href="success.html" class="btn btn-primary">Verify</a>
                                </div>
                            </div>
                        </div>
                    </div>



                </div>

            </div>

        </div>
    </div>
</div>
<!--End::row-1 -->

<script src="~/libs/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="~/scripts/purchaseplanwidget/purchaseplanpublic.js"></script> *@