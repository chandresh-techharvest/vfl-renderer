@model VFL.Renderer.Models.Registration.RegistrationViewModel
@using VFL.Renderer.Models.Registration
@using Progress.Sitefinity.AspNetCore.Mvc.Rendering



<link href="~/vendors/dist/sweetalert2.min.css" rel="stylesheet" />
<script src="/vendors/jquery/jquery-3.6.0.min.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js"></script>
<script src="https://cdnjs.cloudflare.com"></script>
@{
    var lbls = Model.Labels;
}

@if (Model.IsAccountActivationRequest && !Model.ActivationFailed)
{
    <div class="@(string.IsNullOrEmpty(Model.CssClass) ? null : Model.CssClass)" @Html.BuildAttributes(Model.Attributes)>
        <h2 class="mb-3">
            @lbls.ActivationMessage
        </h2>
        <p>
            <a href="@Model.LoginPageUrl">@lbls.LoginLink</a>
        </p>
    </div>
}
else
{
    <div data-sf-role="sf-registration-container"
    data-sf-visibility-hidden="@Model.VisibilityClasses[Progress.Sitefinity.AspNetCore.Configuration.VisibilityStyle.Hidden]"
    data-sf-invalid="@Model.InvalidClass"
    class="card-body @(string.IsNullOrEmpty(Model.CssClass) ? null : Model.CssClass)" @Html.BuildAttributes(Model.Attributes)>

        @if (Model.ShowSuccessMessage(Context))
        {
            <h3>@lbls.SuccessHeader</h3>
            <p>@lbls.SuccessLabel</p>
        }
        else
        {
            var firstNameInputId = Html.GetUniqueId("sf-first-name-");
            var lastNameInputId = Html.GetUniqueId("sf-last-name-");
            var emailInputId = Html.GetUniqueId("sf-email-");
            var passwordInputId = Html.GetUniqueId("sf-new-password-");
            var repeatPasswordInputId = Html.GetUniqueId("sf-repeat-password-");
            var questionInputId = Html.GetUniqueId("sf-secret-question-");
            var answerInputId = Html.GetUniqueId("sf-secret-answer-");
            <script src="/scripts/registration.js" section-name="Bottom"></script>
            @* <environment include="Development">                
                <script src="Scripts/LoginWidgets/registration.js" section-name="Bottom" assembly-ref="Progress.Sitefinity.AspNetCore.Widgets"></script>
            </environment>
            <environment exclude="Development">                
                <script src="Scripts/LoginWidgets/registration.min.js" section-name="Bottom" assembly-ref="Progress.Sitefinity.AspNetCore.Widgets"></script>
            </environment> *@
            <div data-sf-role="form-container" class="authentication-cover">

                <div class="aunthentication-cover-content">
                    <p class="h5 fw-bold mb-2 text-center">
                        @lbls.Header
                    </p>
                    @{
                        string termsConditions = !string.IsNullOrEmpty(Model.TermsConditionsPageUrl) ? Model.TermsConditionsPageUrl : "#";
                    }
                    @if (!string.IsNullOrEmpty(Model.LoginPageUrl))
                    {
                        <div class="text-center">
                            <p class="fs-14 text-muted mt-3">@lbls.LoginLabel <a href="@Model.LoginPageUrl" class="text-primary fw-semibold">@lbls.LoginLink</a></p>
                        </div>
                    }
                    @if (Model.ExternalProviders != null && Model.ExternalProviders.Any())
                    {
                        <div class="d-grid align-items-center">

                            @foreach (var provider in Model.ExternalProviders)
                            {
                                <a data-sf-test="extPrv" class="btn border fs-5 w-100 mt-2 @Model.GetExternalLoginButtonCssClass(provider.Name)" href="@Model.GetExternalLoginPath(Context, provider.Name)">@provider.Title</a>
                            }
                            @*  <button class="btn btn-outline-light border shadow-sm">
                                <img src="../assets/img/authentication/social/1.png" class="w-4 h-4 me-2" alt="google-img">Sign in with Google
                            </button> *@

                        </div>
                    }
                    <div class="text-center my-3 authentication-barrier">
                        <span>OR</span>
                    </div>
                    <div class="alert alert-danger d-none my-3" role="alert" aria-live="assertive">
                        <div data-sf-role="error-message-container">

                        </div>
                        <div class="ResendLink d-none pb-3 align-right text-end" id="ResendLink">
                            <input type="hidden" name="ConfirmVerificationUrl" id="ConfirmVerificationUrl" value="@Model.VerificationPageUrl" />
                            <a href="javascript:void(0);" id="resendConfirmEmail" class="btn btn-primary">Resend Verificaion Email</a>
                        </div>
                    </div>
                    
                    <form method="post" action="@Model.RegistrationHandlerPath" role="form" class="row gy-3">
                        @* @Html.AntiForgeryToken() *@
                        <div class="row">
                            <div class="col-xl-4">
                                <label for="@firstNameInputId" class="form-label text-default op=8">@lbls.FirstNameLabel<span class="text-danger">*</span></label>
                                <input id="@firstNameInputId" type="text" class="form-control form-control-lg" name="FirstName" data-sf-role="required">
                            </div>
                            <div class="col-xl-4">
                                <label for="MiddleName" class="form-label text-default op=8">Middle Name</label>
                                <input id="MiddleName" type="text" class="form-control form-control-lg" name="MiddleName">
                            </div>
                            <div class="col-xl-4">
                                <label for="@lastNameInputId" class="form-label text-default op=8">@lbls.LastNameLabel<span class="text-danger">*</span></label>
                                <input id="@lastNameInputId" type="text" class="form-control form-control-lg" name="LastName" data-sf-role="required">
                            </div>
                        </div>
                        @* <div class="col-xl-6">
                            <label for="Phone" class="form-label text-default op=8">Phone Number</label>
                            <input id="Phone" type="number" pattern="(\+679)?[2356789]\d{6}" placeholder="e.g., +679 7123456"
                                   title="Fiji phone number, including optional country code (+679) followed by 7 digits starting with 2, 3, 5, 6, 7, 8, or 9." class="form-control form-control-lg" name="Phone">
                        </div> *@
                        <div class="col-xl-12">
                            <label for="@emailInputId" class="form-label text-default op=8">@lbls.EmailLabel<span class="text-danger">*</span></label>
                            <input id="@emailInputId" type="email" class="form-control form-control-lg" name="Email" data-sf-role="required">
                        </div>
                        <div class="col-xl-12">
                            <label for="@passwordInputId" class="form-label text-default op=8">@lbls.PasswordLabel<span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input id="@passwordInputId" type="password" class="form-control form-control-lg" name="Password" data-sf-role="required">
                            </div>
                        </div>
                        <div class="col-xl-12 mb-2">
                            <label for="@repeatPasswordInputId" class="form-label text-default op=8">@lbls.RepeatPasswordLabel<span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input id="@repeatPasswordInputId" type="password" class="form-control form-control-lg" name="RepeatPassword" data-sf-role="required">
                            </div>
                            <div class="form-check mt-3">
                                <input class="form-check-input" type="checkbox" data-sf-role="required" value="true" id="termCondition" name="termCondition">
                                <label class="form-check-label text-muted fw-normal" for="termCondition">
                                    I accept the  <a href="@termsConditions" class="text-primary fw-semibold"><u>Terms & Conditions</u><span class="text-danger">*</span></a>
                                </label>
                                <input type="hidden" name="VerificationPageUrl" asp-for="VerificationPageUrl" value="@Model.VerificationPageUrl" />
                            </div>
                        </div>

                        @if (Model.RequiresQuestionAndAnswer)
                        {
                            <div class="mb-3">
                                <label for="@questionInputId" class="form-label">@lbls.SecretQuestionLabel</label>
                                <input id="@questionInputId" type="text" class="form-control" name="Question" data-sf-role="required">
                            </div>
                            <div class="mb-3">
                                <label for="@answerInputId" class="form-label">@lbls.SecretAnswerLabel</label>
                                <input id="@answerInputId" type="text" class="form-control" name="Answer" data-sf-role="required">
                            </div>
                        }
                        <div class="col-xl-12 d-grid mt-2">
                            <input class="btn btn-lg vodafone-btn mt-1" name="btnRegister" type="submit" value="@lbls.RegisterButtonLabel" />
                            @* <button id="btn">modal test</button> *@
                            <input type="hidden" name="ActivationPageUrl" value="@Model.ActivationPageUrl" />
                            <input type="hidden" value="" name="sf_antiforgery" />
                        </div>

                    </form>

                    @*  @if (!string.IsNullOrEmpty(Model.LoginPageUrl))
                    {
                        <div class="mt-3">@lbls.LoginLabel</div>
                        <a href="@Model.LoginPageUrl" class="text-decoration-none">@lbls.LoginLink</a>
                    } *@

                    @* @if (Model.ExternalProviders != null && Model.ExternalProviders.Any())
                    {
                        <h3 class="mt-3">@lbls.ExternalProvidersHeader</h3>
                        @foreach (var provider in Model.ExternalProviders)
                        {
                            <a data-sf-test="extPrv" class="btn border fs-5 w-100 mt-2 @Model.GetExternalLoginButtonCssClass(provider.Name)" href="@Model.GetExternalLoginPath(Context, provider.Name)">@provider.Title</a>
                        }
                    } *@

                    <input type="hidden" name="RedirectUrl" value="@Model.RedirectUrl" />
                    <input type="hidden" name="PostRegistrationAction" value="@Model.PostRegistrationAction" />
                    <input type="hidden" name="ActivationMethod" value="@Model.ActivationMethod" />
                    <input type="hidden" name="ValidationRequiredMessage" value="@lbls.ValidationRequiredMessage" />
                    <input type="hidden" name="ValidationMismatchMessage" value="@lbls.ValidationMismatchMessage" />
                    <input type="hidden" name="ValidationInvalidEmailMessage" value="@lbls.ValidationInvalidEmailMessage" />
                </div>
            </div>

            <div data-sf-role="success-registration-message-container" class="d-none">
                <h3>@lbls.SuccessHeader</h3>
                <p>@lbls.SuccessLabel</p>
            </div>

            <div data-sf-role="confirm-registration-message-container" class="d-none">
                <h3 data-sf-role="activation-link-header"></h3>
                <p data-sf-role="activation-link-message-container"></p>

                <button data-sf-role="sendAgainLink" class="btn btn-primary"></button>

                <input type="hidden" name="ResendConfirmationEmailUrl" value="@Model.ResendConfirmationEmailHandlerPath" />
                <input type="hidden" name="PleaseCheckYourEmailMessage" value="@lbls.PleaseCheckYourEmailMessage" />
                <input type="hidden" name="PleaseCheckYourEmailAnotherMessage" value="@lbls.PleaseCheckYourEmailAnotherMessage" />
                <input type="hidden" name="SendAgainLink" value="@lbls.SendAgainLink" />
                <input type="hidden" name="ActivateAccountLink" value="@lbls.ActivateAccountLink" />
                <input type="hidden" name="ExistingEmail" value="@Model.Email" />
                <input type="hidden" name="ActivationFailed" value="@Model.ActivationFailed" />
                <input type="hidden" name="PleaseCheckYourEmailHeader" value="@lbls.PleaseCheckYourEmailHeader" />
                <input type="hidden" name="ActivateAccountTitle" value="@lbls.ActivateAccountTitle" />
                <input type="hidden" name="ActivateAccountMessage" value="@lbls.ActivateAccountMessage" />
            </div>
        }
    </div>
}


<div class="modal fade" id="emailverification" tabindex="-1"
     aria-labelledby="emailverification" data-bs-keyboard="false"
     aria-hidden="true">
    <!-- Scrollable modal -->
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="staticBackdropLabel3">
                    Email Verification
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" id="btnModalClose"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>The verification link has been sent to your email address. Please check your inbox and follow the instructions to complete your registration.</p>
            </div>
            <div class="modal-footer">      
                <input type="hidden" name="ModalVerificationUrl" id="ModalVerificationUrl" value="@Model.VerificationPageUrl" />
                <a href="javascript:void(0);" id="resendVerification" class="btn btn-primary">Resend Verificaion Email</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmationEmail" tabindex="-1"
     aria-labelledby="confirmationEmail" data-bs-keyboard="false"
     aria-hidden="true">
    <!-- Scrollable modal -->
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="staticBackdropLabel3">
                    Email Already Registered
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" id="btnModalClose"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Email Already registered. Please use different email or confirm email</p>
            </div>
            <div class="modal-footer">
                <input type="hidden" name="ConfirmVerificationUrl" id="ConfirmVerificationUrl" value="@Model.VerificationPageUrl" />
                <a href="javascript:void(0);" id="resendConfirmEmail" class="btn btn-primary">Resend Verificaion Email</a>
            </div>
        </div>
    </div>
</div>


<!-- OR by using the BUNDLED JAVASCRIPT -->


<script src="~/vendors/dist/sweetalert2.min.js"></script>