<div>
    <form role="form" method="post" action="/api/dashboard/AddDevice">
        <div class="modal fade" id="ModalAddDevice" tabindex="-1" aria-hidden="true" data-bs-backdrop="static"
             data-bs-keyboard="false">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="Modalbalancedetails">Add Devices</h6>
                    </div>

                    <div class="modal-body" id="modelbody">
                        <div data-sf-role="form-container" data-sf-visibility-hidden="d-none" data-sf-invalid="is-invalid">
                            <div data-sf-role="error-message-container" class="alert alert-danger d-none my-3" role="alert" aria-live="assertive"></div>

                            <div class="mb-3">
                                <label for="number" class="form-label">  Phone Number *</label>
                                <input type="number" id="number" min="7" maxlength="7" class="form-control" data-sf-role='required' name="number" />
                            </div>





                            <div class="mb-3">

                                <label for="name" class="form-label"> Device Name *</label>
                                <input type="text" id="name" class="form-control" data-sf-role='required' name="name" />

                            </div>



                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-secondary" data-bs-dismiss="modal" id="btnCloseAddDevice">Close</button>

                            <!-- IMPORTANT -->
                            <button class="btn btn-primary" type="button" id="btnSendOtp">Add</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="modal fade" id="otpmodal" tabindex="-1" aria-labelledby="otpmodal" data-bs-keyboard="false" aria-hidden="true"    data-bs-backdrop="static"
   >
            <!-- Scrollable modal -->
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="staticBackdropLabel2">OTP Verification</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="btnCloseData"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-4">Please enter the 4 digit code sent to <span id="maskedNumber"></span></p>
                        <div class="alert alert-success d-none" id="otpSuccessMessage" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            The OTP code has been successfully sent. Please check your messages.
                        </div>
                        <div class="alert alert-info d-none" id="otpResendInfoMessage" role="alert">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            The Resend button is enabled. Please click to resend SMS if you have not received it.
                        </div>
                        <p class="text-muted mb-3">
                            <span id="otpTimer" class="me-auto text-muted">30</span>
                        </p>

                        <div class="mb-3">
                            <input type="number" class="form-control" id="otpCode" name="otpCode" maxlength="6">

                        </div>

                    </div>
                    <div class="modal-footer">
                        <input type="hidden" id="oCresponse" name="oCresponse" />
                        <button type="button" class="btn btn-secondary" id="btnResendOtp">Resend</button>
                        <button class="btn btn-primary" name="btnAddDevice" id="btnAddDevice" type="submit" value="Add Device">Verify</button>
                    </div>
                </div>
            </div>
        </div>
    </form>



</div>


