                                                </tr>
                                                <tr>
                                                    <td>Plan Name</td>
                                                    <td id="successplanName"></td>
                                                </tr>
                                                <tr>
                                                    <td>Sender Number</td>
                                                    <td id="successSender"></td>
                                                </tr>
                                                <tr>
                                                    <td>Receiver Number</td>
                                                    <td id="successReciever"></td>
                                                </tr>



                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <p class="mt-3">You will receive an Email and SMS pertaining to your transaction details. <br>Thank you for shopping with us.</p>

                                <div class="mt-4 d-flex justify-content-center flex-wrap" id="ButtonContainer">
                                    <!-- <a href="" class="btn btn-primary mb-2 mb-md-0 me-2">Chat</a> -->
                                    <a href="/" class="btn btn-primary mb-2 mb-md-0 me-2">Customer Support</a>
                                    <a href="prepay-gifting" class="btn btn-primary">Back</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

