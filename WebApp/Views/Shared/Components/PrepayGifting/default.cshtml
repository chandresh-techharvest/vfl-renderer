@model VFL.Renderer.ViewModels.PrepayGifting.PrepayGiftingViewModel;

<div class="row" id="prepaygifting-default-view">
    <div class="col-xl-12">
        <div class="card custom-card">
            <div class="card-header">
                <div class="card-title">Vodafone Gifting</div>
            </div>

            <div class="card-body">
                <h6 class="mb-3">With Vodafone Data Gifting, you can send part of your mobile data to another Vodafone number anytime, anywhere.</h6>
                <div id="errorBox" class="alert alert-danger" style="display:none;"></div>
                <form class="row g-3 needs-validation" novalidate>
                    
                    <div class="col-md-7 mt-4">
                        <h6 id="gifterInfoBox"
                             class="mb-3"
                             style="">
                        </h6>
                        <label for="mobile_number" class="form-label">Mobile Number</label>
                        <div class="input-group mb-3">
                            <span class="input-group-text" id="basic-addon12">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     class="text-muted" viewBox="0 0 16 16">
                                    <path d="M3.654 1.328a.678.678 0 0 1 1.015-.063L6.29 2.911c.328.329.445.81.293 1.243l-.547 1.548a.678.678 0 0 1-.588.439c-.295.03-.637.064-1.012.102a11.65 11.65 0 0 0 5.516 5.516c.038-.375.072-.717.102-1.012a.678.678 0 0 1 .439-.588l1.548-.547a1.02 1.02 0 0 1 1.243.293l1.646 1.621a.678.678 0 0 1-.063 1.015l-2.29 2.29c-.345.345-.82.515-1.29.45C5.885 13.86 2.14 10.115 1.095 5.572c-.065-.47.105-.945.45-1.29l2.29-2.29Z" />
                                </svg>
                            </span>
                            <input type="number" class="form-control" placeholder="Mobile Number" aria-label="Email Address" aria-describedby="basic-addon12" id="mobile_number" name="mobile_number">
                        </div>
                       
                    </div>
                    <div class="col-md-12 d-flex justify-content-end">
                        <button type="button" id="btnContinue" class="btn btn-primary" disabled>

                            Continue
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>




<div class="row" id="selected-plan-view" style="display:none;">
    <div class="col-xl-12">
        <div class="card custom-card">
            <div class="card-body">
                <ul class="nav nav-tabs tab-style-1 d-sm-flex d-block" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" data-bs-target="#4gplans" href="#4gplans">4G Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" data-bs-target="#5gplans" href="#5gplans">5G Plans</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane active" id="4gplans" role="tabpanel">
                        <div class="row">
                            <div class="col-xl-12">
                                <div class="card custom-card bg-light">
                                    <div class="card-body">
                                        <form class="row row-cols-lg-auto g-3 align-items-center">
                                            <div class="col-12">
                                                @* <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Plan Type</label>
                                                    <select class="form-select" id="inputGroupSelect01">
                                                        <option selected>All Categories</option>
                                                        <option value="1">Data</option>
                                                        <option value="2">Voice</option>
                                                        <option value="3">SMS</option>
                                                    </select>
                                                </div> *@
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Sort By</label>
                                                    <select class="form-select" id="sortFilter">
                                                        <option value="price_asc">Price: Low to High</option>
                                                        <option value="price_desc">Price: High to Low</option>
                                                       
                                                    </select>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap justify-content-start gap-3 py-2">
                            <div class="row g-3 plan-selector" id="plansContainer">

                              
                                

                            </div>
                        </div>



                        <!-- Pagination -->
                        <nav aria-label="Page navigation" class=" pagination-style-3 mt-3">
                            <ul class="pagination mb-0 flex-wrap" id="pagination4g"></ul>
                        </nav>
                    </div>

                    <div class="tab-pane" id="5gplans" role="tabpanel">
                        <div class="row">
                            <div class="col-xl-12">
                                <div class="card custom-card bg-light">
                                    <div class="card-body">
                                        <form class="row row-cols-lg-auto g-3 align-items-center">
                                            <div class="col-12">
                                               
                                            </div>
                                            <div class="col-12">
                                                <div class="input-group">
                                                    <label class="input-group-text" for="inputGroupSelect01">Sort By</label>
                                                    <select class="form-select" id="sortFilter5g">
                                                        <option value="price_asc">Price: Low to High</option>
                                                        <option value="price_desc">Price: High to Low</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap justify-content-start gap-3 py-2">
                            <div class="row g-3 plan-selector" id="plansContainer5g">

                              
                            </div>
                        </div>

                        <!-- Pagination -->
                        <nav aria-label="Page navigation" class=" pagination-style-3 mt-3">
                            <ul class="pagination mb-0 flex-wrap" id="pagination5g"></ul>
                        </nav>
                    </div>


                </div>
                <div class="row">
                    <div class="col-md-12 mt-3">
                        <div class="d-flex justify-content-between">
                            <a href="prepay-gifting" class="btn btn-primary" style="width: 100px;">Previous</a>
                            <a href="javascript:void(0)" class="btn btn-primary" id="btnSubscribe" style="width: 100px;" >Continue</a>
                        </div>
                    </div>

                    <div class="modal fade" id="Modalplandetails" tabindex="-1" aria-labelledby="exampleModalFullscreenLabel" aria-hidden="true" style="display: none;">
                        <div class="modal-dialog modal-fullscreen">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="exampleModalFullscreenLabel">Plan Details</h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body d-flex justify-content-center">
                                    <div class="col-lg-6 col-md-10 col-sm-12">
                                        <ul class="fs-14 ps-3">
                                        </ul>
                                    </div>
                                </div>

                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">
                                    Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>









                    <!-- confirmation modal -->
                    <div class="modal fade" id="ModalConfirmation-prepaygifting" tabindex="-1"
                         aria-labelledby="exampleModalScrollable2" data-bs-keyboard="false"
                         aria-hidden="true">
                        <!-- Scrollable modal -->
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">
                                        Confirmation
                                    </h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                                            aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Dear <span id="confirmUser"></span>,</p>
                                    <p>You are about to gift the following plan:</p>

                                    <ul class="list-unstyled mb-3">
                                        <li><strong>Plan Name:</strong> <span id="confirmPlan"></span></li>
                                        <li><strong>Price:</strong> <span id="confirmPrice"></span></li>
                                       
                                        <li><strong>Mobile Number:</strong> <span id="confirmNumber"></span></li>
                                    <li><strong>Summary:</strong> <span id="confirmSummary"></span></li>
                                    </ul>

                                    <p>Do you wish to continue with the subscription?</p>
                                </div>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>

                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModalScrollable2">Confirm</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- OTP Option -->
                    <div class="modal fade" id="exampleModalScrollable2" tabindex="-1" aria-labelledby="exampleModalScrollable2" data-bs-keyboard="false" aria-hidden="true">

                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">Select OTP Verification Method</h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <form>
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <div class="form-check form-check-md">
                                                <input class="form-check-input" type="radio" name="otpOption" id="otpMobile" value="1" style="border: 1px solid rgb(117, 117, 117);">
                                                <label class="form-check-label" for="otpMobile"> Send OTP via SMS</label>
                                            </div>
                                            <div class="form-check form-check-md">
                                                <input class="form-check-input" type="radio" name="otpOption" id="otpEmail" value="2" style="border: 1px solid rgb(117, 117, 117);">
                                                <label class="form-check-label" for="otpEmail"> Send OTP via Email</label>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                            data-bs-dismiss="modal">
                                        Close
                                    </button>
                                    @* <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#otpmodal"  >verify</button> *@
                                    <button type="button"
                                            id="btnSendOtp"
                                            class="btn btn-primary">
                                        Verify
                                    </button>

                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- OTP -->
                    <div class="modal fade" id="otpmodal" tabindex="-1" aria-labelledby="otpmodal" data-bs-keyboard="false" aria-hidden="true">
                        <!-- Scrollable modal -->
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h6 class="modal-title" id="staticBackdropLabel2">OTP Verification</h6>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="mb-4" id="otpMessage">Please enter the 4 digit code sent to </p>
                                    <div class="alert alert-success d-none" id="otpSuccessMessage" role="alert">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        The OTP code has been successfully sent. Please check your messages.
                                    </div>
                                    <div class="alert alert-info d-none" id="otpResendInfoMessage" role="alert">
                                        <i class="bi bi-info-circle-fill me-2"></i>
                                        The Resend button is enabled. Please click to resend SMS if you have not received it.
                                    </div>
                                    <p class="text-muted mb-3">
                                        <span id="otpTimer" class="me-auto text-muted">30</span>
                                    </p>
                                    <form>
                                        <div class="mb-3">
                                            <input type="text" class="form-control" id="otpCode">
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <input type="hidden" id="oCresponse" name="oCresponse" />
                                    <button type="button" class="btn btn-secondary" id="btnResendOtp">Resend</button>
                                    @* <a href="success.html" confirmCheckoutBtn class="btn btn-primary">Verify</a> *@
                                    <button class="btn btn-primary" name="btnprepaygiftingsubscribe" id="btnprepaygiftingsubscribe" type="submit" value="Subscribe">Verify</button>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>


