@using Progress.Sitefinity.AspNetCore.Mvc.Rendering
@model VFL.Renderer.ViewModels.MyBillTransactionHistory.MyBillTransactionHistoryViewModel

@{
    bool isDesignerMode = Model.IsDesignerMode;
    bool isAuthenticated = Model.IsAuthenticated;
    bool hasPreviewData = Model.PreviewTransactions != null && Model.PreviewTransactions.Length > 0;
}

@if (isDesignerMode)
{
    <!-- PREVIEW MODE for Sitefinity Designer -->
    <div class="alert alert-info mb-3">
        <i class="ri-information-line me-2"></i>
        <strong>Preview Mode:</strong> This is how the transaction history will look for authenticated MyBill users.
    </div>
}

<!-- Transaction History Widget -->
<div id="mybillTransactionHistory" 
     class="card custom-card" 
     data-page-size="@Model.PageSize"
     data-authenticated="@Model.IsAuthenticated.ToString().ToLower()"
     data-designer-mode="@Model.IsDesignerMode.ToString().ToLower()">
    
    <div class="card-header justify-content-between">
        <div class="card-title">@Model.WidgetTitle</div>
        @if (Model.ShowSearch)
        {
            <div>
                <input class="form-control form-control-sm" 
                       type="text" 
                       id="txnSearchInput" 
                       placeholder="Search transactions..." 
                       aria-label="Search transactions" />
            </div>
        }
    </div>
    
    <!-- Filter Bar -->
    <div class="card-body border-bottom py-3" id="txnFilterBar" style="background-color: #f8f9fa;">
        <div class="row g-3 align-items-end">
            <div class="col-xl col-md-4 col-sm-6">
                <label for="txnFilterBan" class="form-label mb-1 fw-semibold small text-muted">BAN</label>
                <select class="form-select form-select-sm" id="txnFilterBan" aria-label="Filter by BAN account">
                    <option value="">All Accounts</option>
                </select>
            </div>
            <div class="col-xl col-md-4 col-sm-6">
                <label for="txnFilterInvoice" class="form-label mb-1 fw-semibold small text-muted">Invoice number</label>
                <input type="text" class="form-control form-control-sm" id="txnFilterInvoice" placeholder="Enter invoice number..." aria-label="Filter by invoice number" />
            </div>
            <div class="col-xl col-md-4 col-sm-6">
                <label for="txnFilterPaymentStatus" class="form-label mb-1 fw-semibold small text-muted">Payment status</label>
                <select class="form-select form-select-sm" id="txnFilterPaymentStatus" aria-label="Filter by payment status">
                    <option value="">All Status</option>
                    <option value="Success">Success</option>
                    <option value="Failed">Failed</option>
                </select>
            </div>
            <div class="col-xl col-md-4 col-sm-6">
                <label for="txnFilterDateFrom" class="form-label mb-1 fw-semibold small text-muted">Date from</label>
                <input type="date" class="form-control form-control-sm" id="txnFilterDateFrom" aria-label="Filter date from" />
            </div>
            <div class="col-xl col-md-4 col-sm-6">
                <label for="txnFilterDateTo" class="form-label mb-1 fw-semibold small text-muted">Date to</label>
                <input type="date" class="form-control form-control-sm" id="txnFilterDateTo" aria-label="Filter date to" />
            </div>
            <div class="col-xl-auto col-md-4 col-sm-6">
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary btn-sm" id="txnApplyFilters">
                        <i class="ri-filter-3-line me-1"></i>Apply Filters
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="txnResetFilters">Reset</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <!-- Loading State -->
        <div id="txnLoadingState" class="text-center py-5 @(isDesignerMode ? "d-none" : "")">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading transaction history...</p>
        </div>
        
        <!-- Error State -->
        <div id="txnErrorState" class="d-none text-center py-5">
            <i class="ri-error-warning-line fs-1 text-danger"></i>
            <p class="mt-2 text-danger" id="txnErrorMessage">An error occurred while loading transactions.</p>
            <button class="btn btn-primary btn-sm" id="txnRetryBtn">
                <i class="ri-refresh-line me-1"></i> Retry
            </button>
        </div>
        
        <!-- Empty State -->
        <div id="txnEmptyState" class="d-none text-center py-5">
            <i class="ri-file-list-3-line fs-1 text-muted" style="font-size: 3rem !important;"></i>
            <p class="mt-2 text-muted">No transactions found.</p>
        </div>
        
        <!-- Transaction Table -->
        <div id="txnTableContainer" class="@(isDesignerMode ? "" : "d-none")">
            <div class="table-responsive">
                <table class="table text-nowrap mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Reference</th>
                            <th>Invoice</th>
                            <th>Account (BAN)</th>
                            <th>Payment Method</th>
                            <th>Amount</th>
                            <th>Partial</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="txnTableBody">
                        @if (isDesignerMode && hasPreviewData)
                        {
                            foreach (var txn in Model.PreviewTransactions)
                            {
                                var statusClass = txn.Status switch
                                {
                                    "Success" => "bg-success",
                                    "Failed" => "bg-danger",
                                    _ => "bg-warning"
                                };
                                
                                <tr>
                                    <td>@txn.Date.ToString("dd MMM yyyy")</td>
                                    <td><code>@txn.Reference</code></td>
                                    <td>@txn.InvoiceNumber</td>
                                    <td>@txn.AccountName (@txn.Ban)</td>
                                    <td>@txn.PaymentMethod</td>
                                    <td class="fw-semibold">$@txn.Amount.ToString("N2")</td>
                                    <td>@txn.PartialPayment</td>
                                    <td><span class="badge @statusClass">@txn.Status</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Pagination Footer -->
    <div class="card-footer d-flex justify-content-between align-items-center" id="txnPaginationFooter">
        <div class="text-muted" id="txnPaginationInfo">
            Showing <span id="txnPageStart">0</span> to <span id="txnPageEnd">0</span> of <span id="txnTotalRecords">0</span> entries
        </div>
        <nav aria-label="Transaction pagination">
            <ul class="pagination pagination-sm mb-0" id="txnPaginationControls">
                <li class="page-item disabled" id="txnPrevPage">
                    <a class="page-link" href="javascript:void(0);">
                        <i class="ri-arrow-left-s-line"></i> Previous
                    </a>
                </li>
                <li class="page-item" id="txnPageInfo">
                    <span class="page-link bg-light">Page <span id="txnCurrentPage">1</span></span>
                </li>
                <li class="page-item" id="txnNextPage">
                    <a class="page-link" href="javascript:void(0);">
                        Next <i class="ri-arrow-right-s-line"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Include Token Auto-Refresh Script -->
<script>
    window.mybillConfig = window.mybillConfig || {};
    window.mybillConfig.jwtExpiryMinutes = @(ViewBag.MyBillJwtExpiryMinutes ?? 14);
    window.mybillConfig.loginPath = '@Html.Raw(ViewBag.MyBillLoginPath ?? "/my-bill-login")';
</script>
<script src="~/scripts/MyBillWidgets/mybill-auth-refresh.js" asp-append-version="true"></script>

<!-- Include Transaction History JavaScript -->
<script src="~/scripts/MyBillWidgets/mybill-transaction-history.js" asp-append-version="true"></script>
