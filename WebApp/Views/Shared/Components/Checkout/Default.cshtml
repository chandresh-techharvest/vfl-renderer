@model VFL.Renderer.ViewModels.Checkout.CheckoutViewModel

@{
    string customerPageUrl = !String.IsNullOrEmpty(Model.CustomerSuportPageUrl) ? Model.CustomerSuportPageUrl : "/";
    string homePageUrl = !String.IsNullOrEmpty(Model.HomePageUrl) ? Model.HomePageUrl : "/";
}
@{
    string TermsConditionsUrl = Model.TermsConditionsPage != null ? Model.TermsConditionsPage.ViewUrl : "#";
}

<div id="checkout-view">
    <form>


    @Html.AntiForgeryToken()

    <!-- hidden data coming from WebTopUp -->
    <input type="hidden" name="Email" value="@Model.Email" />
    <input type="hidden" name="PhoneNumber" value="@Model.PhoneNumber" />
    <input type="hidden" name="PlanCode" value="@Model.PlanCode" />
    <input type="hidden" name="Amount" value="@Model.Amount" />
        <input type="hidden" name="PageType" value="@Model.PageType" />
        <input type="hidden" name="PageUrl" value="@Model.PageUrl" />

    @*<input type="hidden" name="PaymentMethod" id="paymentMethod" /> *@
    <input type="hidden" name="sid"
           value="@Context.Request.Query["sid"]" />

    <!-- Start::row-1 -->
        <div class="row">

            <div class="col-xl-12">
                <div class="row">
                    <div class="col-xl-12">
                        <div class="card custom-card p-3">
                            <div class="row">
                                <div class="col-xl-4 col-sm-12">

                                    <div class="card-body p-0">
                                        <div class="card-body">
                                            <ul class="list-group">
                                                <li class="list-group-item list-item-solid-light">
                                                    <div class="d-flex align-items-center">
                                                        <span class="fw-semibold fs-20">Order Information</span>
                                                    </div>
                                                </li>

                                                <li class="list-group-item">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-medium fs-14">Amount:</span>
                                                        <span class="fw-medium">$ @Model.Amount</span>
                                                    </div>
                                                </li>
                                                <li class="list-group-item">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-medium fs-14">Number:</span>
                                                        <span class="fw-medium">@Model.PhoneNumber</span>
                                                    </div>

                                                </li>
                                                <li class="list-group-item" id="planNameRow" style="display:none;">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-medium fs-14">Plan Name:</span>
                                                        <span class="fw-medium" id="planName"></span>
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>



                                    </div>
                                </div>
                                <div class="col-xl-6 col-sm-12 offset-xl-1">
                                    <div class="d-flex justify-content-between">
                                        <h5 class="fw-semibold">Payment Method</h5>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <p class="fw-semibold">Please select a payment option:</p>
                                    </div>
                                    <div class="row mt-3 gt-4">
                                        <div class="col-xxl-3 col-xl-3 col-sm-12">
                                            <div class="card custom-card">
                                                <div class="card-body text-center mx-auto">
                                                    <input class="form-check-input payment-card border-0" type="radio" value="MPAISA" name="paymentMethod" id="Radio-sm3">
                                                    <span class="payment-card-style">
                                                        <img src="~/images/img/payment-cards/14.png" alt="" class="payment-card-style">
                                                    </span>
                                                    <div class="">
                                                        <p class="mb-0 fw-semibold">M-Paisa</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-xxl-3 col-xl-3 col-sm-12">
                                            <div class="card custom-card">
                                                <div class="card-body text-center mx-auto">
                                                    <input class="form-check-input payment-card border-0" type="radio" name="paymentMethod"  id="Radio-sm5" value="CARD">
                                                    <span class="payment-card-style">
                                                        <img src="~/images/img/payment-cards/5.png" alt="" class="payment-card-style">
                                                    </span>
                                                    <div class="">
                                                        <p class="mb-0 fw-semibold">Master card</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-xxl-3 col-xl-3 col-sm-12">
                                            <div class="card custom-card">
                                                <div class="card-body text-center mx-auto">
                                                    <input class="form-check-input payment-card border-0" type="radio" name="paymentMethod" value="CARD" id="Radio-sm5">
                                                    <span class="payment-card-style">
                                                        <img src="~/images/img/payment-cards/6.png" alt="" class="payment-card-style">
                                                    </span>
                                                    <div class="">
                                                        <p class="mb-0 fw-semibold">Visa card</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>
        <div class="row" id="billingAddressSection" style="display:none;">
            <div class="d-flex justify-content-between">
                <h5 class="fw-semibold">Billing Address</h5>
            </div>
            <div class="row mt-3">
                <div class="col-xl-12">
                    <div class="card custom-card">
                        <div class="card-body">

                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <input name="FirstName" class="form-control required-field" data-label="First name" />
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <input name="LastName" class="form-control required-field" data-label="Last name" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">Email</label>
                                    <input id="billingEmail" name="BillingEmail" class="form-control required-field" data-label="Email" />
                                    <div class="invalid-feedback"></div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <input name="BillingPhone" class="form-control required-field" data-label="Phone" />
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">Address 1</label>
                                    <input name="Address1" class="form-control required-field" data-label="Address" />
                                    <div class="invalid-feedback"></div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Address 2</label>
                                    <input name="Address2" class="form-control" />

                                </div>
                            </div>
                            <div class="row">

                                <div class="col-md-6">
                                    <label class="form-label">Address 3</label>
                                    <input name="Address3" class="form-control" placeholder="1234 Main St" />
                                </div>


                                <div class="col-md-4">
                                    <label for="inputCountry" class="form-label">Country</label>
                                    <select id="inputCountry" name="CountryCode" class="form-select required-field"
                                            data-label="Country">
                                        <option selected>Choose...</option>


                                    </select>
                                    <div class="invalid-feedback"></div>
                                </div>

                            </div>
                          
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label">State</label>
                                    <input name="State" class="form-control required-field" data-label="State" />
                                    <div class="invalid-feedback"></div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Postal</label>
                                    <input name="PostalCode" class="form-control required-field" data-label="Postal code" />
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-4">
                                    <label for="inputstate" class="form-label">City</label>
                                    <input type="text" name="City" class="form-control required-field" data-label="City" id="inputcity">
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                            
                            <div class="col-12 mt-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="invalidCheck" required>
                                    <label class="form-check-label" for="invalidCheck">
                                        <a href="@TermsConditionsUrl" class="text-primary fw-semibold"><u>Agree to terms and conditions</u> </a>
                                    </label>
                                    <div class="invalid-feedback">
                                        You must agree before submitting.
                                    </div>
                                </div>
                            </div>

                         
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 mt-3 mb-3">
                <div class="d-flex justify-content-between">
                
                    <button type="button" class="btn btn-primary" style="width: 100px;" id="backBtn">Back</button>
                    <button type="button" class="btn btn-primary" id="placeOrderBtn">Proceed</button>
                </div>

                <!-- confirmation modal -->
                <div class="modal fade" id="exampleModalScrollable2" tabindex="-1" aria-labelledby="exampleModalScrollable2" data-bs-keyboard="false" aria-hidden="true">
                    <!-- Scrollable modal -->
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h6 class="modal-title" id="staticBackdropLabel2">Confirmation</h6>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body" id="confirmBody">
                                <p>
                                    You are about to recharge device. Please review the details below before proceeding:
                                </p>

                                <table class="table table-bordered mt-3">
                                    <tr>
                                        <td><b>Number</b></td>
                                        <td id="confirmNumber">-</td>
                                    </tr>
                                    <tr>
                                        <td><b>Amount</b></td>
                                        <td id="confirmAmount"></td>
                                    </tr>
                                    <tr>
                                        <td><b>Payment Method</b></td>
                                        <td id="confirmPayment">-</td>
                                    </tr>
                                </table>
                            </div>

                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="button" class="btn btn-primary" id="checkoutBtn">
                                    Proceed
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
</form>
</div>

<!-- Start::result-1 -->

