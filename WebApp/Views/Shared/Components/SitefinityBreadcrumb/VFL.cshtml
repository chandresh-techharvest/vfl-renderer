@using Progress.Sitefinity.AspNetCore.Mvc.Rendering
@model Progress.Sitefinity.AspNetCore.Widgets.Models.Breadcrumb.BreadcrumbViewModel

<!-- breadcrumb -->
<section class="breadcrumb-header">
    <div class="container">
        <!-- breadcrumb-text -->
        @if (!string.IsNullOrEmpty(Model.PageMissingMessage))
        {
            <div class="@Model.CssClass" @Html.BuildAttributes(Model.Attributes)>@Model.PageMissingMessage</div>
        }
        else
        {
            <div class="breadcrumb-header-inner">
                <ul class="breadcrumb-text list-unstyled" data-wow-duration="1500ms" data-wow-delay="300ms">
                    @for (int i = 0; i < Model.Pages.Count; i++)
                    {
                        var node = Model.Pages[i];

                        if (i == Model.Pages.Count - 1)
                        {
                            <li>
                                <a class="breadcrumb-home active" href="@node.ViewUrl">@node.Title</a>
                            </li>
                        }
                        else
                        {
                            <li><a class="breadcrumb-home" href="@node.ViewUrl">@node.Title</a></li>
                            <li><span class="breadcrumb-separator">›</span></li>
                        }
                    }
                </ul>
            </div>
        }

        </div>
</section>