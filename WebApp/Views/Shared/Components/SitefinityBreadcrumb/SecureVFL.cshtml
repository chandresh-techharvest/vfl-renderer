@using Progress.Sitefinity.AspNetCore.Mvc.Rendering
@model Progress.Sitefinity.AspNetCore.Widgets.Models.Breadcrumb.BreadcrumbViewModel

<!-- breadcrumb -->
<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    @if (!string.IsNullOrEmpty(Model.PageMissingMessage))
    {
        <div class="@Model.CssClass" @Html.BuildAttributes(Model.Attributes)>@Model.PageMissingMessage</div>
    }
    else
    {
        <h1 class="page-title fw-medium fs-24 mb-0">@Model.Pages[Model.Pages.Count - 1].Title</h1>
        <div class="ms-md-1 ms-0">
            <nav>
                <ol class="breadcrumb mb-0">

                    @for (int i = 0; i < Model.Pages.Count; i++)
                    {
                        var node = Model.Pages[i];

                        if (i == Model.Pages.Count - 1)
                        {
                            <li class="breadcrumb-item active d-inline-flex" aria-current="page">
                                @node.Title
                            </li>
                        }
                        else
                        {
                            <li class="breadcrumb-item" aria-current="page"><a href="@node.ViewUrl">@node.Title</a></li>
                        }
                    }
                </ol>
            </nav>
        </div>
    }
</div>